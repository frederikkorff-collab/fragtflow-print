{
  "name": "fragtflow-print",
  "version": "1.0.0",
  "description": "FragtFlow Print Client — polls the FragtFlow print queue and prints shipping labels automatically.",
  "main": "dist/main/index.js",
  "author": "FragtFlow",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "node scripts/copy-assets.js",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:publish": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-log": "^5.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "pdf-to-printer": "^5.8.0",
    "unix-print": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1",
    "typescript": "^5.3.3"
  }
}
